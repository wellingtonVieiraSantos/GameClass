# Environment Variables — Backend
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to version control.

# ── Database ────────────────────────────────────────────────────────────────
# Full PostgreSQL connection string used by Prisma.
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://user:password@localhost:5432/gameclass?schema=public"

# ── Authentication ───────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens. Use a long, random string.
JWT_SECRET="change-me-to-a-long-random-secret"

# JWT token expiration time (e.g., 1d, 6h, 30m)
JWT_EXPIRES_IN="1d"

# ── Application ──────────────────────────────────────────────────────────────
# Port the server listens on (default: 3000)
PORT=3000

# Node environment: development | test | production
NODE_ENV="development"

# ── CORS ────────────────────────────────────────────────────────────────────
# Allowed origin(s) for cross-origin requests (frontend URL)
CORS_ORIGIN="http://localhost:5173"
