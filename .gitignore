# Root-level .gitignore for the GameClass monorepo

# Environment files — NEVER commit
.env
.env.*
!.env.example

# OS
.DS_Store
Thumbs.db

# IDEs
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/

# Node
node_modules/

# Build outputs
dist/
build/
.next/
out/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
.nyc_output/

# Temporary
.temp/
.tmp/
*.pid
*.pid.lock
